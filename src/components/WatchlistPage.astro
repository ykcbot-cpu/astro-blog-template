---
import BaseLayout from '../layouts/BaseLayout.astro';
import recommendations from '../data/recommendations.json';
import shortlist from '../data/shortlist.json';

const {
  current = 'watchlist',
  permalink = `${Astro.site.href}watchlist`,
} = Astro.props;

const title = 'Watchlist';
const description = 'Current KumoTrade watchlist, recommendations, and ranked action shortlist.';
---

<BaseLayout title={title} description={description} permalink={permalink} current={current}>
  <div class="container dashboard">
    <header class="page-header">
      <p class="eyebrow">As of {recommendations.asOf}</p>
      <h1>Watchlist</h1>
      <p class="summary">{recommendations.summary}</p>
    </header>

    <section class="regime-grid" aria-label="Market gates">
      <div class="metric">
        <span>Regime</span>
        <strong>{recommendations.regime.classification}</strong>
      </div>
      <div class="metric">
        <span>Market Gate</span>
        <strong>{recommendations.regime.marketGate}</strong>
      </div>
      <div class="metric">
        <span>Risk Pause</span>
        <strong>{recommendations.regime.riskPause}</strong>
      </div>
    </section>

    <section class="table-wrap" aria-label="Current shortlist">
      <h2>Ranked Shortlist</h2>
      <table class="watchlist-table shortlist-table">
        <colgroup>
          <col class="col-rank" />
          <col class="col-name" />
          <col class="col-type" />
          <col class="col-score" />
          <col class="col-thesis" />
          <col class="col-action" />
        </colgroup>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Name</th>
            <th>Type</th>
            <th>Score</th>
            <th>Thesis</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {shortlist.items.map((item) => (
            <tr>
              <td>{item.rank}</td>
              <td><strong>{item.name}</strong></td>
              <td>{item.type}</td>
              <td>{item.score}</td>
              <td>{item.thesisStatus}</td>
              <td>{item.action}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="New company watchlist">
      <h2>New Company Watchlist</h2>
      <table class="watchlist-table detail-table">
        <colgroup>
          <col class="col-ticker" />
          <col class="col-rec" />
          <col class="col-trigger" />
          <col class="col-stop" />
          <col class="col-target" />
          <col class="col-status" />
          <col class="col-follow" />
        </colgroup>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Recommendation</th>
            <th>Trigger</th>
            <th>Stop</th>
            <th>Target</th>
            <th>Status</th>
            <th>Follow-up</th>
          </tr>
        </thead>
        <tbody>
          {recommendations.watchlist.map((item) => (
            <tr>
              <td><strong>{item.ticker}</strong></td>
              <td>{item.recommendation}</td>
              <td>{item.trigger}</td>
              <td>{item.stop}</td>
              <td>{item.target}</td>
              <td>{item.status}</td>
              <td>{item.followUp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="Active recommendations">
      <h2>Active Holdings Actions</h2>
      <table class="watchlist-table detail-table">
        <colgroup>
          <col class="col-ticker" />
          <col class="col-rec" />
          <col class="col-trigger" />
          <col class="col-stop" />
          <col class="col-target" />
          <col class="col-status" />
          <col class="col-follow" />
        </colgroup>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Recommendation</th>
            <th>Trigger</th>
            <th>Stop</th>
            <th>Target</th>
            <th>Status</th>
            <th>Follow-up</th>
          </tr>
        </thead>
        <tbody>
          {recommendations.active.map((item) => (
            <tr>
              <td><strong>{item.ticker}</strong></td>
              <td>{item.recommendation}</td>
              <td>{item.trigger}</td>
              <td>{item.stop}</td>
              <td>{item.target}</td>
              <td>{item.status}</td>
              <td>{item.followUp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="Completed or removed recommendations">
      <h2>Completed / Removed</h2>
      <table class="watchlist-table completed-table">
        <colgroup>
          <col class="col-ticker" />
          <col class="col-outcome" />
          <col class="col-follow" />
        </colgroup>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Outcome</th>
            <th>Follow-up</th>
          </tr>
        </thead>
        <tbody>
          {recommendations.completedOrRemoved.map((item) => (
            <tr>
              <td><strong>{item.ticker}</strong></td>
              <td>{item.outcome}</td>
              <td>{item.followUp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </div>
</BaseLayout>

<style>
  .dashboard {
    max-width: 84em;
  }

  .page-header {
    margin: 2rem 0;
  }

  .eyebrow,
  .summary,
  .metric {
    font-family: var(--font-family-sans);
    font-weight: 700;
  }

  .eyebrow,
  .summary {
    color: var(--text-secondary);
    margin: 0;
    text-transform: uppercase;
  }

  .summary {
    max-width: 68rem;
    text-transform: none;
  }

  .regime-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 2rem 0 0;
  }

  .metric {
    border: 1px solid rgba(84, 142, 155, 0.35);
    border-radius: 8px;
    min-height: 132px;
    padding: 1rem;
  }

  .metric span {
    color: var(--text-secondary);
    display: block;
    font-size: 0.85rem;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
  }

  .metric strong {
    display: block;
    font-size: 1.15rem;
    line-height: 1.35;
  }

  .table-wrap {
    margin-top: 2.5rem;
    overflow-x: auto;
  }

  .watchlist-table {
    min-width: 980px;
    table-layout: fixed;
    width: 100%;
  }

  .detail-table {
    min-width: 1220px;
  }

  .completed-table {
    min-width: 880px;
  }

  .watchlist-table th,
  .watchlist-table td {
    overflow-wrap: anywhere;
    vertical-align: top;
  }

  .col-rank {
    width: 6%;
  }

  .col-name,
  .col-ticker {
    width: 9%;
  }

  .col-type,
  .col-rec,
  .col-thesis,
  .col-status {
    width: 15%;
  }

  .col-score,
  .col-stop,
  .col-target {
    width: 9%;
  }

  .col-trigger,
  .col-action,
  .col-follow {
    width: 24%;
  }

  .col-outcome {
    width: 44%;
  }

  @media (max-width: 900px) {
    .regime-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
