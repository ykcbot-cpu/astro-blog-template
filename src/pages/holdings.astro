---
import BaseLayout from '../layouts/BaseLayout.astro';
import holdings from '../data/holdings.json';

const title = 'Holdings';
const description = 'Current KumoTrade portfolio holdings and risk posture.';
const permalink = `${Astro.site.href}holdings`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="holdings">
  <div class="container dashboard">
    <header class="page-header">
      <p class="eyebrow">As of {holdings.asOf}</p>
      <h1>Holdings</h1>
      <p class="summary">{holdings.regime}</p>
    </header>

    <section class="metrics" aria-label="Portfolio exposure">
      <div>
        <span>Gross exposure</span>
        <strong>{holdings.exposure.grossExposurePct}%</strong>
      </div>
      <div>
        <span>Net exposure</span>
        <strong>{holdings.exposure.netExposurePct}%</strong>
      </div>
      <div>
        <span>Recommended net</span>
        <strong>{holdings.exposure.recommendedNetExposurePct}%</strong>
      </div>
    </section>

    <section class="table-wrap" aria-label="Active holdings">
      <h2>Active Holdings</h2>
      <table>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Direction</th>
            <th>Qty</th>
            <th>Entry</th>
            <th>Score</th>
            <th>Thesis</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {holdings.positions.map((position) => (
            <tr>
              <td><strong>{position.ticker}</strong></td>
              <td>{position.direction}</td>
              <td>{position.quantity}</td>
              <td>{position.entryPrice}</td>
              <td>{position.score}</td>
              <td>{position.thesis}</td>
              <td>{position.action}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="Recently closed positions">
      <h2>Recently Closed</h2>
      <table>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Direction</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>Realized P&L</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          {holdings.recentlyClosed.map((position) => (
            <tr>
              <td><strong>{position.ticker}</strong></td>
              <td>{position.direction}</td>
              <td>{position.entryPrice}</td>
              <td>{position.exitPrice}</td>
              <td>{position.realizedPnlUsd}</td>
              <td>{position.reason}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </div>
</BaseLayout>

<style>
  .dashboard {
    max-width: 72em;
  }

  .page-header {
    margin: 2rem 0;
  }

  .eyebrow,
  .summary {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
  }

  .metrics {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 2rem 0;
  }

  .metrics div {
    border: 1px solid rgba(84, 142, 155, 0.35);
    border-radius: 8px;
    padding: 1rem;
  }

  .metrics span {
    color: var(--text-secondary);
    display: block;
    font-family: var(--font-family-sans);
    font-weight: 700;
    text-transform: uppercase;
  }

  .metrics strong {
    display: block;
    font-family: var(--font-family-sans);
    font-size: 1.8rem;
    margin-top: 0.4rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  table {
    min-width: 780px;
    width: 100%;
  }

  @media (max-width: 760px) {
    .metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
