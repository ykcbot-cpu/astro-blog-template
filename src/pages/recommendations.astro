---
import BaseLayout from '../layouts/BaseLayout.astro';
import recommendations from '../data/recommendations.json';
import fullList from '../data/shortlist.json';

const title = 'Recommendations';
const description = 'Current KumoTrade recommendations and ranked full list.';
const permalink = `${Astro.site.href}recommendations`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="recommendations">
  <div class="container dashboard">
    <header class="page-header">
      <p class="eyebrow">As of {recommendations.asOf}</p>
      <h1>Recommendations</h1>
      <p class="summary">{recommendations.summary}</p>
    </header>

    <section class="table-wrap" aria-label="Current full list">
      <h2>{fullList.label}</h2>
      <table>
        <thead>
          <tr>
            <th class="numeric">Rank</th>
            <th class="compact">Name</th>
            <th class="compact">Type</th>
            <th class="compact">Category</th>
            <th class="compact">Added</th>
            <th class="compact">Last Reviewed</th>
            <th class="compact">Score</th>
            <th class="long">Thesis</th>
            <th class="long">Action</th>
          </tr>
        </thead>
        <tbody>
          {fullList.items.map((item) => (
            <tr>
              <td class="numeric">{item.rank}</td>
              <td class="compact"><strong>{item.name}</strong></td>
              <td class="compact">{item.type}</td>
              <td class="compact">{item.category}</td>
              <td class="compact">{item.addedDate}</td>
              <td class="compact">{item.lastReviewedAt}</td>
              <td class="compact">{item.score}</td>
              <td class="long">{item.thesisStatus}</td>
              <td class="long">{item.action}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="Active recommendations">
      <h2>Active Recommendations</h2>
      <table>
        <thead>
          <tr>
            <th class="compact">Ticker</th>
            <th class="compact">Recommendation</th>
            <th class="compact">Category</th>
            <th class="compact">Added</th>
            <th class="compact">Last Reviewed</th>
            <th class="long">Trigger</th>
            <th class="compact">Stop</th>
            <th class="compact">Target</th>
            <th class="long">Status</th>
          </tr>
        </thead>
        <tbody>
          {recommendations.active.map((item) => (
            <tr>
              <td class="compact"><strong>{item.ticker}</strong></td>
              <td class="compact">{item.recommendation}</td>
              <td class="compact">{item.category}</td>
              <td class="compact">{item.addedDate}</td>
              <td class="compact">{item.lastReviewedAt}</td>
              <td class="long">{item.trigger}</td>
              <td class="compact">{item.stop}</td>
              <td class="compact">{item.target}</td>
              <td class="long">{item.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="table-wrap" aria-label="Completed or removed recommendations">
      <h2>Completed / Removed</h2>
      <table>
        <thead>
          <tr>
            <th class="compact">Ticker</th>
            <th class="long">Outcome</th>
            <th class="long">Follow-up</th>
          </tr>
        </thead>
        <tbody>
          {recommendations.completedOrRemoved.map((item) => (
            <tr>
              <td class="compact"><strong>{item.ticker}</strong></td>
              <td class="long">{item.outcome}</td>
              <td class="long">{item.followUp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </div>
</BaseLayout>

<style>
  .dashboard {
    max-width: 78em;
  }

  .page-header {
    margin: 2rem 0;
  }

  .eyebrow,
  .summary {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
  }

  .summary {
    max-width: 60rem;
    text-transform: none;
  }

  .table-wrap {
    margin-top: 2rem;
    overflow-x: auto;
  }

  table {
    table-layout: auto;
    width: max-content;
  }

  .compact,
  .numeric {
    white-space: nowrap;
  }

  .numeric {
    text-align: right;
  }

  .long {
    max-width: 26rem;
    min-width: 16rem;
    white-space: normal;
  }
</style>
