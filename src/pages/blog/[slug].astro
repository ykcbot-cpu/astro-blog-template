---
import readingTime from 'reading-time'
import BaseLayout from '../../layouts/BaseLayout.astro';
import Bio from '../../components/Bio.astro';
import { getPostSummary } from '../../data/postSummaries.js';

export async function getStaticPaths() {
	const postModules = import.meta.glob('../../data/blog-posts/*.md', { eager: true });
  const posts = Object.values(postModules).map((post) => ({
    data: post.frontmatter,
    Content: post.Content,
    raw: post.rawContent?.() ?? '',
  }));
  return posts.map(p => ({
    params: { slug: p.data.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props
const { title, slug, description, publishDate } = post.data;
const readingTimeEstimate = readingTime(post.raw).text
const permalink = `${Astro.site.href}blog/${slug}`;
const { Content } = post
const summary = getPostSummary(slug);
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <header>
    <p>{publishDate} ~ {readingTimeEstimate}</p>
    <h1>{title}</h1>
    <hr />
  </header>
  <div class="container">
    {summary && (
      <aside class="post-summary" aria-label="Post summary">
        <div class="summary-heading">
          <span>Post Summary</span>
          <strong>{summary.correctionStatus}</strong>
        </div>
        <dl>
          <div>
            <dt>Timestamp</dt>
            <dd>{publishDate} SGT</dd>
          </div>
          <div>
            <dt>Report Type</dt>
            <dd>{summary.type}</dd>
          </div>
          <div>
            <dt>Regime</dt>
            <dd>{summary.regime}</dd>
          </div>
          <div>
            <dt>Portfolio Stance</dt>
            <dd>{summary.stance}</dd>
          </div>
          <div>
            <dt>Main Action</dt>
            <dd>{summary.mainAction}</dd>
          </div>
          <div>
            <dt>Key Holding / Action</dt>
            <dd>{summary.keyHoldingAction}</dd>
          </div>
          <div>
            <dt>Key Risk</dt>
            <dd>{summary.keyRisk}</dd>
          </div>
          <div>
            <dt>P&amp;L Impact</dt>
            <dd>{summary.pnlImpact}</dd>
          </div>
        </dl>
      </aside>
    )}
    <article class="content">
      <Content />
    </article>
    <hr />
    <Bio />
  </div>
</BaseLayout>

<style>
  header {
    text-align: center;
  }

  header h1 {
    margin-bottom: 0.7em;
  }

  header p {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-family: var(--font-family-sans);
    font-weight: 600;
  }

  header hr {
    min-width: 100px;
    width: 30%;
  }

  .post-summary {
    border: 1px solid rgba(84, 142, 155, 0.35);
    border-left: 4px solid var(--primary-color);
    border-radius: 8px;
    margin: 0 0 2rem;
    padding: 1rem 1.1rem;
  }

  .summary-heading,
  .post-summary dt,
  .post-summary dd {
    font-family: var(--font-family-sans);
  }

  .summary-heading {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 0.9rem;
  }

  .summary-heading span {
    color: var(--primary-color);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .summary-heading strong {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .post-summary dl {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0;
  }

  .post-summary div {
    min-width: 0;
  }

  .post-summary dt {
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    text-transform: uppercase;
  }

  .post-summary dd {
    font-size: 0.98rem;
    line-height: 1.45;
    margin: 0;
  }

  .content :global(table) {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    table-layout: auto;
    width: max-content;
  }

  .content :global(th),
  .content :global(td) {
    white-space: nowrap;
  }

  .content :global(th:nth-last-child(-n + 2)),
  .content :global(td:nth-last-child(-n + 2)) {
    max-width: 24rem;
    min-width: 14rem;
    white-space: normal;
  }

  @media (max-width: 720px) {
    .summary-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }

    .post-summary dl {
      grid-template-columns: 1fr;
    }
  }
</style>
