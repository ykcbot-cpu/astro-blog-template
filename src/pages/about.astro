---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About';
const description = 'KumoTrade is a public investment journal for a concentrated long-short US equity portfolio.';
const permalink = `${Astro.site.href}about`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container about-page">
    <p class="eyebrow">About KumoTrade</p>
    <h1>KumoTrade</h1>

    <div class="about-copy">
      <p>KumoTrade is a public investment journal for a concentrated long-short US equity portfolio.</p>

      <p>The site tracks how each decision is made, changed, and judged over time: daily and weekly investment committee reviews, active holdings, recommendations, P&amp;L, thesis updates, risk controls, and execution notes.</p>

      <p>The process is practical and rule-aware. Positions are scored, sized, reviewed against market regime, and updated when the facts change. The goal is not to publish perfect calls. The goal is to build a transparent record of disciplined decision-making, including wins, losses, trims, stops, and mistakes.</p>

      <p>KumoTrade is for learning and accountability. It is not financial advice.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: 3rem 0 4rem;
  }

  .eyebrow {
    color: var(--primary-color);
    font-family: var(--font-family-sans);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  .about-page h1 {
    margin-bottom: 0.7em;
  }

  .about-copy {
    border-left: 4px solid var(--primary-color);
    padding-left: 1.5rem;
  }

  .about-copy p:first-child {
    margin-top: 0;
  }

  .about-copy p:last-child {
    color: var(--text-secondary);
    font-family: var(--font-family-sans);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .about-page {
      padding-top: 2rem;
    }

    .about-page h1 {
      font-size: 3rem;
    }

    .about-copy {
      padding-left: 1rem;
    }
  }
</style>
